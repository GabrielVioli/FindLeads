generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  QUALIFIED
  CONTACTED
  RESPONDED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  ARCHIVED
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Lead {
  id              String       @id @default(cuid())
  businessName    String
  tradeName       String?
  document        String?      @unique
  documentType    String?
  phone           String?
  whatsapp        String?
  email           String?
  website         String?
  instagram       String?
  city            String?
  state           String?
  neighborhood    String?
  address         String?
  niche           String?
  cnaeCode        String?
  cnaeDescription String?
  companyStatus   String?
  openingDate     DateTime?
  source          String?
  sourceUrl       String?
  score           Int          @default(0)
  status          LeadStatus   @default(NEW)
  priority        LeadPriority @default(MEDIUM)
  notes           String?
  lastContactAt   DateTime?
  nextActionAt    DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  leadNotes       LeadNote[]

  @@index([businessName])
  @@index([city])
  @@index([niche])
  @@index([status])
  @@index([priority])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  content   String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadImport {
  id           String   @id @default(cuid())
  fileName     String
  totalRows    Int
  importedRows Int
  failedRows   Int
  createdAt    DateTime @default(now())
}

model SearchConfig {
  id         String   @id @default(cuid())
  city       String
  state      String
  niche      String
  maxResults Int      @default(20)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
